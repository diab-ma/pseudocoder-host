          "kind": "assistant_message",
          "created_at": 2000,
          "provider": "claude",
          "status": "in_progress",
          "markdown": "Hello world"
        }
      ]
    },
    {
      "label": "continuation with bracketed paste tilde and two-char ESC sequences",
