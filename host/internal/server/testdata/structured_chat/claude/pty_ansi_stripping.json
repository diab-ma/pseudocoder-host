      "expect_status": "timeline_changed",
      "expect_timeline": [
        {
          "id": "claude-user:turn-1",
          "session_id": "session-claude-ansi",
          "kind": "user_message",
          "created_at": 1000,
          "provider": "claude",
          "status": "completed",
          "text": "test"
        },
        {
          "id": "claude-assistant:turn-1",
          "session_id": "session-claude-ansi",
          "kind": "assistant_message",
          "created_at": 2000,
          "provider": "claude",
          "status": "in_progress",
          "markdown": "Hello world\nMore text"
        }
      ]
    },
    {
      "label": "blank line finalizes assistant",
      "chunk_observed_at": 2200,
      "chunks": ["\n"],
      "expect_status": "timeline_changed",
      "expect_timeline": [
        {
          "id": "claude-user:turn-1",
